#!/bin/sh

echo "Running cargo fmt..."
cargo fmt --all -- --check

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Commit failed: Rust code is not formatted correctly."
  echo "Please run 'cargo fmt --all' to fix formatting, then try your commit again."
  exit 1
fi

echo "Running cargo clippy..."
cd apps/server && cargo clippy --all-targets -- -D warnings

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Commit failed: Clippy found warnings."
  echo "Please fix the clippy warnings before committing."
  exit 1
fi

exit 0
