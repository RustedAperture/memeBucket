BIND_ADDR=0.0.0.0:8080
DATABASE_URL=sqlite://data/app.db
STATIC_DIR=/app/web
APP_USER_KEY_SECRET=replace-with-32-plus-random-bytes
SESSION_SECRET=replace-with-32-plus-random-bytes
DISCORD_APPLICATION_ID=replace-me
DISCORD_PUBLIC_KEY=replace-me
DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_BOT_TOKEN=replace-me
DISCORD_OAUTH_REDIRECT_URL=https://example.com/auth/discord/callback
PUBLIC_BASE_URL=https://example.com
KLIPY_API_KEY=your-klipy-api-key-here

# Telegram Login (optional — omit to disable Telegram auth)
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=replace-me

# Media permanence — Backblaze B2 + Cloudflare (optional — omit to disable CDN re-hosting)
B2_KEY_ID=replace-me
B2_APP_KEY=replace-me
B2_BUCKET_NAME=memebucket-media
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
CDN_BASE_URL=https://media.memebucket.app
